<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CEO Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <a href="/" style="color: white; text-decoration: none;">← Home</a>
            <h1>CEO Dashboard 🔐</h1>
        </header>

        <div class="card">
            <h3>Tambah API Key OpenRouter</h3>
            <p style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 10px;">
                Dapatkan key baru di <a href="https://openrouter.ai/keys" target="_blank" style="color: #3b82f6;">openrouter.ai</a>
            </p>
            <form action="/ceo/add-key" method="POST" style="margin-top: 15px;">
                <input type="text" name="key" placeholder="sk-or-v1-..." required>
                <button type="submit" class="btn">Simpan Key</button>
            </form>
        </div>

        <div class="card">
            <h3>Active Keys Database</h3>
            <% if(keys.length > 0) { %>
                <ul style="list-style: none; padding: 0;">
                    <% keys.forEach((k, index) => { %>
                        <li style="padding: 10px; border-bottom: 1px solid #334155; display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: #94a3b8; font-family: monospace;">
                                Key #<%= index + 1 %>: <%= k.key.substring(0, 15) %>...
                            </span>
                            
                            <!-- Tombol Hapus Key -->
                            <form action="/ceo/delete-key" method="POST" style="margin:0;">
                                <input type="hidden" name="id" value="<%= k._id %>">
                                <button type="submit" style="background: #ef4444; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer;">
                                    Hapus 🗑️
                                </button>
                            </form>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <p style="color: #ef4444;">⚠️ Belum ada API Key! Chat tidak akan berfungsi.</p>
            <% } %>
        </div>
    </div>
</body>
</html>
